# Default local dev: SQLite file next to schema (see prisma/dev.db after db push)
DATABASE_URL="file:./dev.db"

# For PostgreSQL instead (e.g. docker compose), use:
# DATABASE_URL="postgresql://pluginai:pluginai@localhost:5432/pluginai"
# and set datasource provider to postgresql in prisma/schema.prisma

JWT_SECRET="change-me-in-production-min-32-chars-long!!"
PORT=4000
WEB_ORIGIN="http://localhost:3000"

# 1 = no Redis required (scans run in API process). For BullMQ + Redis, set to 0 and run Redis.
SYNC_SCANS=1
