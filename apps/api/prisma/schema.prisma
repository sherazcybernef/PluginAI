generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum PlatformType {
  WORDPRESS
  SHOPIFY
  FRAMER
  UNKNOWN
}

enum ScanKind {
  crawl
  lab
  full
}

enum ScanStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  BLOCKER
}

enum PillarKind {
  PERFORMANCE
  DISCOVERABILITY
  CONTENT
}

enum Confidence {
  HIGH
  MEDIUM
  LOW
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  name         String?
  createdAt    DateTime    @default(now())
  workspaces   Workspace[]
}

model Workspace {
  id             String   @id @default(cuid())
  ownerId        String
  name           String
  slug           String   @unique
  planKey        String   @default("free")
  creditsBalance Int      @default(100)
  createdAt      DateTime @default(now())

  owner User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sites Site[]

  @@index([ownerId])
}

model Site {
  id          String       @id @default(cuid())
  workspaceId String
  url         String
  platform    PlatformType @default(UNKNOWN)
  name        String?
  verified    Boolean      @default(false)
  createdAt   DateTime     @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  scans     Scan[]
  issues    Issue[]

  @@index([workspaceId])
}

model Scan {
  id                 String     @id @default(cuid())
  siteId             String
  kind               ScanKind   @default(full)
  status             ScanStatus @default(QUEUED)
  pageBudgetConsumed Int        @default(0)
  error              String?
  startedAt          DateTime   @default(now())
  finishedAt         DateTime?

  site  Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  issues Issue[]
  score  ScoreSnapshot?

  @@index([siteId])
}

model Issue {
  id             String        @id @default(cuid())
  scanId         String
  siteId         String
  issueType      String
  pillar         PillarKind
  severity       IssueSeverity
  title          String
  description    String
  impactEstimate Float?
  confidence     Confidence    @default(MEDIUM)
  evidence       Json?
  fixCatalogId   String?

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@index([siteId])
}

model ScoreSnapshot {
  id                     String   @id @default(cuid())
  scanId                 String   @unique
  siteId                 String
  overallPercent         Float
  performancePercent     Float
  discoverabilityPercent Float
  contentPercent         Float
  scoringEngineVersion   String   @default("1.0.0-mvp")
  createdAt              DateTime @default(now())

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([siteId])
}
